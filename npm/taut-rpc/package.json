{
  "name": "taut-rpc",
  "version": "0.1.0",
  "description": "TypeScript runtime for taut-rpc — end-to-end type-safe RPC between Rust (axum) and TypeScript clients.",
  "keywords": [
    "rpc",
    "axum",
    "rust",
    "typescript",
    "validation",
    "valibot",
    "zod",
    "sse"
  ],
  "homepage": "https://github.com/nktkt/taut-rpc",
  "bugs": {
    "url": "https://github.com/nktkt/taut-rpc/issues"
  },
  "author": "taut-rpc contributors",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "https://github.com/nktkt/taut-rpc.git",
    "directory": "npm/taut-rpc"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js",
      "default": "./dist/http.js"
    },
    "./sse": {
      "types": "./dist/sse.d.ts",
      "import": "./dist/sse.js",
      "default": "./dist/sse.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "valibot": "^0.42.0",
    "zod": "^3.23.0"
  },
  "peerDependenciesMeta": {
    "valibot": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
