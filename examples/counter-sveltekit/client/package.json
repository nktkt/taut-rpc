{
  "name": "counter-sveltekit-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "build-api": "cd ../../.. && cargo run -p taut-rpc-cli -- taut gen --from-binary examples/counter-sveltekit/server/target/debug/counter-sveltekit-server --out examples/counter-sveltekit/client/src/lib/api.gen.ts",
    "typecheck": "svelte-kit sync && tsc --noEmit"
  },
  "dependencies": {
